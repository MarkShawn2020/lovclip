{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lovclip",
  "version": "5.1.0",
  "identifier": "com.neurora.lovclip",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:7777",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Lovclip",
        "width": 680,
        "height": 480,
        "minWidth": 500,
        "minHeight": 350,
        "maxWidth": 1000,
        "maxHeight": 700,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      },
      {
        "label": "archive",
        "title": "Lovclip 档案库",
        "url": "index.html#archive",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": false,
        "center": true
      },
      {
        "label": "settings",
        "title": "Lovclip 设置",
        "url": "index.html#settings",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "exceptionDomain": null,
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
